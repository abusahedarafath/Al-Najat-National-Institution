<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arabic Awal Admission 2027</title>

    <link rel="stylesheet" href="/css/admission2027.css">
</head>

<body>

<%- include('./partials/hero') %>

<section class="section">

    <div class="container">

        <div class="section-title">
            <h2>Arabic Awal Admission</h2>
            <p>Read the admission information carefully before applying.</p>
        </div>

        <div class="course-card">

            <h3>Eligibility</h3>

            <ul>
                <li>Class V Passed or equivalent.</li>
                <li>Hifz completed (where applicable).</li>
                <li>Must satisfy the institution's admission requirements.</li>
            </ul>

            <hr>

            <h3>Required Documents</h3>

            <ul>
                <li>PEN Number</li>
                <li>APAAR ID</li>
                <li>Siksha Setu ID</li>
                <li>Birth Certificate</li>
                <li>Transfer Certificate (TC)</li>
                <li>Passport-size Photograph</li>
                <li>Student Signature</li>
                <li>Aadhaar (if available)</li>
            </ul>

            <hr>

            <h3>Admission Process</h3>

            <ol>
                <li>Fill in the online application.</li>
                <li>Upload all required documents.</li>
                <li>Document verification.</li>
                <li>Entrance Test (if applicable).</li>
                <li>Merit list publication.</li>
                <li>Final admission.</li>
            </ol>

            <br>

            <a href="/admission2027/apply"  class="btn-primary">
                Apply Now
            </a>

        </div>

    </div>

</section>

</html>
