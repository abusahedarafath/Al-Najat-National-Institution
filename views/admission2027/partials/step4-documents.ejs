<div class="wizard-step" id="step4" style="display:none;">

    <h2>Step 4: Document Upload</h2>
    <p>Upload the required documents. Accepted formats: PDF, JPG, JPEG, PNG (Max 2 MB each).</p>

    <div class="form-grid">

        <div class="form-group">
            <label>Passport Size Photo *</label>
            <input type="file" name="photo" accept=".jpg,.jpeg,.png" required>
        </div>

        <div class="form-group">
            <label>Student Signature *</label>
            <input type="file" name="signature" accept=".jpg,.jpeg,.png" required>
        </div>

        <div class="form-group">
            <label>Birth Certificate / Age Proof *</label>
            <input type="file" name="birth_certificate" accept=".pdf,.jpg,.jpeg,.png" required>
        </div>

        <div class="form-group">
            <label>Transfer Certificate (TC)</label>
            <input type="file" name="tc" accept=".pdf,.jpg,.jpeg,.png">
        </div>

        <div class="form-group">
            <label>Previous Marksheet</label>
            <input type="file" name="marksheet" accept=".pdf,.jpg,.jpeg,.png">
        </div>

        <div class="form-group">
            <label>Aadhaar Card (Optional)</label>
            <input type="file" name="aadhaar" accept=".pdf,.jpg,.jpeg,.png">
        </div>

    </div>

    <div class="wizard-buttons">

        <button type="button" class="btn-secondary" id="backStep4">
            ← Previous
        </button>

        <button type="button" class="btn-primary" id="nextStep4">
            Next →
        </button>

    </div>

</div>
