<div class="wizard-step" id="step5" style="display:none;">

    <h2>Step 5: Review & Submit</h2>

    <p>
        Please review your application carefully before submitting.
        Ensure that all information is correct.
    </p>

    <div class="preview-card">

        <h3>Application Preview</h3>

        <div id="previewContent"></div>

    </div>

    <div class="declaration-box">

        <label>

            <input
                type="checkbox"
                id="declaration"
                required>

            I hereby declare that all the information provided by me is
            true and correct to the best of my knowledge. I understand
            that providing false information may result in rejection
            of my admission.

        </label>

    </div>

    <div class="wizard-buttons">

        <button
            type="button"
            class="btn-secondary"
            id="backStep5">

            ← Previous

        </button>

        <button
            type="submit"
            class="btn-primary"
            id="submitApplication"
            disabled>

            Submit Application

        </button>

    </div>

</div>
