            <p>10 May 2027</p>
        </div>

        <div class="info-card">
            <h3>Session</h3>
            <p>2027–28</p>
        </div>

    </div>

</section>
<section id="courses" class="courses">

    <h2>Choose Your Course</h2>

<div class="course-grid">

    <div class="course-card">
        <h3>Arabic Awal</h3>
        <p>Fresh Admission</p>
        <a href="/apply?course=arabic-awal" class="btn">Apply</a>
    </div>

    <div class="course-card">
        <h3>Foundation Course</h3>
        <p>ETFC</p>
        <a href="/apply?course=foundation-course" class="btn">Apply</a>
    </div>

    <div class="course-card">
        <h3>Dawra Foundation</h3>
        <p>DCFC</p>
        <a href="/apply?course=dawra-foundation" class="btn">Apply</a>
